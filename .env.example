# =============================================================================
# .env.example — Copy this to .env for local development
# NEVER commit .env to git
# =============================================================================

# ---- Flask ------------------------------------------------------------------
FLASK_ENV=development
FLASK_CONFIG=development
SECRET_KEY=change-me-to-a-random-64-char-string

# ---- Database ---------------------------------------------------------------
# Local (docker-compose):  postgresql://weddingadmin:localdevpassword@localhost:5432/wedding_db
# Azure:                   Injected via Key Vault reference in App Service
DATABASE_URL=postgresql://weddingadmin:localdevpassword@localhost:5432/wedding_db

# ---- Azure OpenAI -----------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=                    # Leave blank in production — use managed identity
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ---- Azure Blob Storage -----------------------------------------------------
BLOB_STORAGE_URL=https://<your-storage-account>.blob.core.windows.net/
BLOB_CONTAINER_NAME=photos

# ---- Gmail SMTP (OTP email delivery) ---------------------------------------
# 1. Enable 2-Step Verification: myaccount.google.com → Security
# 2. Create App Password: Security → App passwords → "Wedding Site"
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_NAME=Haj & Pierce

# ---- Application Insights ---------------------------------------------------
APPINSIGHTS_INSTRUMENTATIONKEY=         # Leave blank to disable telemetry locally

# ---- Admin ------------------------------------------------------------------
# Comma-separated list of email addresses that have admin access
ADMIN_EMAILS=your@email.com,partner@email.com

# ---- OTP / Session ----------------------------------------------------------
OTP_EXPIRY_MINUTES=10
